FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ARG APPTAINER_VERSION=1.4.5

# Install Slurm (includes slurmctld, slurmd, slurm-client), slurmdbd, Munge, and utilities
RUN apt-get update && apt-get install -y \
    slurm-wlm \
    slurmdbd \
    munge \
    gosu \
    postgresql-client \
    curl \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install Apptainer inside the image so compute nodes can run .sif containers natively.
# Follows the UPPMAX pattern: Slurm + Apptainer coexist on each compute node.
RUN ARCH=$(dpkg --print-architecture) \
    && curl -fsSL \
       "https://github.com/apptainer/apptainer/releases/download/v${APPTAINER_VERSION}/apptainer_${APPTAINER_VERSION}_${ARCH}.deb" \
       -o /tmp/apptainer.deb \
    && apt-get install -y /tmp/apptainer.deb \
    && rm /tmp/apptainer.deb \
    && apptainer --version

# Pin slurm user/group to UID/GID 990 so they are consistent across all nodes
RUN groupmod --gid 990 slurm 2>/dev/null || groupadd -r --gid 990 slurm \
    && usermod --uid 990 slurm 2>/dev/null || useradd -r -g slurm --uid 990 slurm

# Create required runtime directories with correct ownership
RUN mkdir -m 0755 -p \
        /var/run/slurm \
        /var/spool/slurm \
        /var/lib/slurm \
        /var/log/slurm \
        /etc/slurm \
    && chown slurm:slurm \
        /var/run/slurm \
        /var/spool/slurm \
        /var/lib/slurm \
        /var/log/slurm \
        /etc/slurm

# Install dask[distributed] so compute nodes can run dask-scheduler and
# dask-worker processes launched as Slurm jobs.
# --break-system-packages is required on Ubuntu 24.04 (PEP 668).
RUN pip3 install --break-system-packages --no-cache-dir "dask[distributed]"

COPY docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["slurmd"]
